{
  "manifest_version": 3,
  "name": "PromptYourMint",
  "version": "1.0",
  "description": "Extracts math exercises from mintsh.de and formats them into Claude-ready prompts.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.mintsh.de/*"],
      "js": ["content.js"]
    }
  ],
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["*://*.mintsh.de/*"]
}
